# RTIS MegaVPN production node-agent environment template.
# Release: 7.0.1.6
# Copy to /etc/megavpn/agent.env with mode 0600 or render via SSH bootstrap.

MEGAVPN_AGENT_CONTROL_PLANE_URL=https://control.example.com:58765
MEGAVPN_AGENT_NODE_ID=replace-node-uuid
MEGAVPN_AGENT_NODE_NAME=edge-1
MEGAVPN_AGENT_NODE_ADDRESS=203.0.113.10

# First enrollment only. Remove after the agent has persisted its state.
MEGAVPN_AGENT_ENROLLMENT_TOKEN=replace-one-time-enrollment-token

# Legacy shared token fallback must stay empty in production.
MEGAVPN_AGENT_TOKEN=
MEGAVPN_AGENT_ALLOW_AUTO_REGISTER=false

MEGAVPN_AGENT_SIGNATURE_ENFORCE=true
MEGAVPN_AGENT_SIGNATURE_WINDOW=5m
MEGAVPN_AGENT_POLL_INTERVAL=10s
MEGAVPN_AGENT_STATE_PATH=/var/lib/megavpn/agent/state.json
MEGAVPN_AGENT_BOOTSTRAP_PATH=/etc/megavpn/agent-bootstrap.env
MEGAVPN_LOG_LEVEL=info
