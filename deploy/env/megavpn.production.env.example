# RTIS MegaVPN production control-plane environment template.
# Copy to /etc/megavpn/megavpn.env with mode 0600 and replace every value.

MEGAVPN_DATABASE_DSN=postgres://megavpn:replace-password@127.0.0.1:5432/megavpn?sslmode=verify-full
MEGAVPN_API_LISTEN_ADDR=127.0.0.1:8080
MEGAVPN_PUBLIC_BASE_URL=https://control.example.com:58765
MEGAVPN_PRODUCTION_MODE=true
MEGAVPN_TRUST_PROXY_HEADERS=true
MEGAVPN_WEB_ROOT=/opt/megavpn/web
MEGAVPN_ARTIFACT_ROOT=/var/lib/megavpn/artifacts

MEGAVPN_MASTER_KEY_PATH=/etc/megavpn/master.key
MEGAVPN_MASTER_KEY_VERSION=v1

MEGAVPN_AGENT_ALLOW_AUTO_REGISTER=false
MEGAVPN_AGENT_SIGNATURE_ENFORCE=true
MEGAVPN_AGENT_SIGNATURE_WINDOW=5m

MEGAVPN_AUTH_SESSION_TTL=24h
MEGAVPN_AUTH_SESSION_COOKIE_SECURE=true
MEGAVPN_API_MAX_REQUEST_BYTES=16777216
MEGAVPN_API_READ_TIMEOUT=10s
MEGAVPN_API_WRITE_TIMEOUT=20s
MEGAVPN_API_IDLE_TIMEOUT=60s
MEGAVPN_API_SHUTDOWN_TIMEOUT=10s

MEGAVPN_WORKER_INTERVAL=3s
MEGAVPN_WORKER_LEASE_DURATION=2m
MEGAVPN_WORKER_ID=control-plane-1-worker

MEGAVPN_LOG_LEVEL=info

# Only required if agent capability installation is allowed to install Xray via
# the upstream XTLS installer script. Pin the exact downloaded script SHA-256
# for the release being deployed, or leave unset to fail closed.
# MEGAVPN_XRAY_INSTALL_SCRIPT_SHA256=
